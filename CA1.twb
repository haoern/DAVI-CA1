            <column datatype='real' name='[NumberOfMRTsWithin500Mts]' role='measure' type='quantitative' />
            <column caption='Planning Area Name' datatype='string' name='[PlanningAreaName]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
