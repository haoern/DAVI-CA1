            <column caption='Time To Airport By Public Transport In Seconds' datatype='real' name='[TimeToAirportByPublicTransportInSeconds]' role='measure' type='quantitative' />
            <column caption='Time To Raffles By Public Transport In Seconds' datatype='real' name='[TimeToRafflesByPublicTransportInSeconds]' role='measure' type='quantitative' />
            <column caption='Transacted Price Per Sq Ft' datatype='real' name='[TransactedPricePerSqFt]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1630856850870273]' derivation='Avg' name='[avg:Calculation_1630856850870273:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1630856861667332]' derivation='None' name='[none:Calculation_1630856861667332:nk]' pivot='key' type='nominal' />
