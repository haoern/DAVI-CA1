      <aliases enabled='yes' />
      <column datatype='real' name='[Ameneties_Count]' role='measure' type='quantitative' />
      <column caption='Norm No. of Bus Stops' datatype='real' name='[Calculation_0343878480637953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([NumberOfMRTsWithin500Mts] - {FIXED : MIN([NumberOfMRTsWithin500Mts])}) / ({FIXED : MAX([NumberOfMRTsWithin500Mts])} - {FIXED : MIN([NumberOfMRTsWithin500Mts])})' />
      </column>
      <column caption='Norm No. of Mrts' datatype='real' name='[Calculation_0343878481739778]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([NumberOfMRTsWithin500Mts] - {FIXED : MIN([NumberOfMRTsWithin500Mts])}) / ({FIXED : MAX([NumberOfMRTsWithin500Mts])} - {FIXED : MIN([NumberOfMRTsWithin500Mts])})' />
      </column>
      <column caption='Norm TTR' datatype='real' name='[Calculation_0343878482014211]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - ([TimeToRafflesByPublicTransportInSeconds] - {FIXED : MIN([TimeToRafflesByPublicTransportInSeconds])}) / ({FIXED : MAX([TimeToRafflesByPublicTransportInSeconds])} - {FIXED : MIN([TimeToRafflesByPublicTransportInSeconds])})' />
      </column>
      <column caption='Norm TTA' datatype='real' name='[Calculation_0343878482157572]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - ([TimeToAirportByPublicTransportInSeconds] - {FIXED : MIN([TimeToAirportByPublicTransportInSeconds])}) / ({FIXED : MAX([TimeToAirportByPublicTransportInSeconds])} - {FIXED : MIN([TimeToAirportByPublicTransportInSeconds])})' />
      </column>
      <column caption='Accesibility Score' datatype='real' name='[Calculation_0343878482227205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.35*[Calculation_0343878481739778]+&#13;&#10;0.25*[Calculation_0343878480637953]+&#13;&#10;0.25*[Calculation_0343878482014211]+&#13;&#10;0.15*[Calculation_0343878482157572]' />
      </column>
      <column caption='Value Score' datatype='real' name='[Calculation_1630856850870273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0343878482227205]+([Ameneties_Count] - {FIXED : MIN([Ameneties_Count])}) / ({FIXED : MAX([Ameneties_Count])} - {FIXED : MIN([Ameneties_Count])}))/[TransactedPricePerSqFt]' />
      </column>
      <column caption='Amenity Count Grouping' datatype='string' name='[Calculation_1630856854695938]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Ameneties_Count] &lt;= 1 THEN &quot;Basic&quot;&#13;&#10;&#13;&#10;ELSEIF [Ameneties_Count] &lt;= 3 THEN &quot;Moderate&quot;&#13;&#10;&#13;&#10;ELSEIF [Ameneties_Count] &lt;= 5 THEN &quot;Premium&quot;&#13;&#10;&#13;&#10;ELSE &quot;Luxury&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='KPI (Value Score)' datatype='string' name='[Calculation_1630856861667332]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1630856850870273] &gt;= { FIXED : PERCENTILE([Calculation_1630856850870273], 0.97) } THEN &quot;97 pct&quot; ELSE &quot;Other&quot; END' />
      </column>
